{
  "name": "chealt",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -Apt run dev",
    "build": "yarn workspaces foreach -Apt run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@playwright/test": "latest",
    "jszip": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "playwright-core": "latest"
  },
  "packageManager": "yarn@4.10.3"
}
