{
  "name": "chealt",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -Apt run dev",
    "build": "yarn workspaces foreach -Apt run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt ."
  },
  "devDependencies": {
    "oxfmt": "latest",
    "oxlint": "latest"
  },
  "packageManager": "yarn@4.10.3"
}
